{
  "name": "@quicio/speck",
  "version": "0.1.0",
  "description": "Spec/ADR/milestone/task dashboard for spec-driven projects. Reads Markdown with frontmatter and renders an ASCII dashboard.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "speck": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src tests vitest.config.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "spec",
    "specification",
    "spec-driven",
    "adr",
    "milestone",
    "task",
    "tracker",
    "dashboard",
    "markdown",
    "quicio"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.23.1"
  },
  "dependencies": {
    "chalk": "5.3.0",
    "gray-matter": "4.0.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
